# Wartungsmodus: "true" aktiviert den Maintenance-Screen mit Passwortabfrage.
# Für Produktion auf "false" setzen oder Variable entfernen.
VITE_MAINTENANCE_MODE=true

# Passwort für den Zugang im Wartungsmodus. Nur bei VITE_MAINTENANCE_MODE=true relevant.
# Standard in Entwicklung: ren-dev
VITE_MAINTENANCE_PASSWORD=ren-dev
